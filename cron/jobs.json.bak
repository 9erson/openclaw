      "enabled": true,
      "createdAtMs": 1772513930138,
      "updatedAtMs": 1772586190844,
      "schedule": {
        "kind": "cron",
        "expr": "*/15 * * * *",
        "tz": "UTC"
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "ORCHESTRATOR TICK: Read system/policy.md for rules. Select next channel in round-robin. Check current time (IST). If active hours (05:00-00:00 IST): read channel purpose.md, activity.log, recent messages. CRITICAL: Check activity.log for previous questions - NEVER repeat the same question, even if unanswered. Each tick = NEW question, different angle. Formulate ONE strategic question to move conversation toward purpose, send via message tool. If quiet hours (00:00-05:00 IST): pick task from system/tasks.md or channel tasks.md, execute silently. Log action to system/ops.log and channel activity.log."
      },
      "delivery": {
        "mode": "announce",
        "channel": "discord",
        "to": "user:729703087031320577"
      },
      "state": {
        "nextRunAtMs": 1772586900000,
        "lastRunAtMs": 1772586022526,
